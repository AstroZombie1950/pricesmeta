Options -Indexes
ErrorDocument 404 /404.php

RewriteEngine On

# Статичные файлы отдаём напрямую
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Sitemap
RewriteRule ^sitemap\.xml$ /sitemap.php [L]

# /reset-password
RewriteRule ^reset-password/?$ /reset-password.php [L,QSA]

# /shop/[slug]
RewriteRule ^shop/([a-z0-9_-]+)/?$ /shop/product.php?slug=$1 [L,QSA]

# /articles/[slug]
RewriteRule ^articles/([a-z0-9_-]+)/?$ /articles/article.php?slug=$1 [L,QSA]

# /backstage/*
RewriteRule ^backstage/([a-z0-9_/-]+)/?$ /backstage/index.php?route=$1 [L,QSA]

# Скачивание файлов
RewriteRule ^download/([a-z0-9_-]+)/?$ /download.php?slug=$1 [L,QSA]